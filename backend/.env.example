# 应用配置
APP_NAME=天眼生活助手AI Agent
APP_VERSION=1.0.0
DEBUG=True

# Agent版本配置（v1 或 v2）
AGENT_VERSION=v2

# 数据库配置
DATABASE_URL=mysql://root:password@localhost:3306/tianyan_life
DB_ECHO=False

# Redis配置 - 指定使用db3存储Token
REDIS_URL=redis://localhost:6379/3

# JWT双令牌配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS配置
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5174"]

# 第三方API配置
AMAP_API_KEY=your-amap-key
BAIDU_MAP_API_KEY=your-baidu-map-key
XHS_API_KEY=your-xhs-key
WEATHER_API_KEY=your-weather-key

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100